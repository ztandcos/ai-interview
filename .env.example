PROJECT_NAME=AI Interview Copilot
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_interview

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
VERIFICATION_CODE_TTL_SECONDS=300
VERIFICATION_SEND_COOLDOWN_SECONDS=60

UPLOAD_DIR=uploads/resumes
MAX_RESUME_FILE_SIZE_BYTES=5242880
RESUME_CHUNK_SIZE=800
RESUME_CHUNK_OVERLAP=120
RESUME_SEARCH_DEFAULT_TOP_K=5

# LLM_PROVIDER 可选值：
# - mock：不调用真实模型，用本地规则生成题目/评分/追问
# - ollama：调用本机 Ollama，使用 OLLAMA_* 配置
# - deepseek：调用 DeepSeek/OpenAI-compatible API，使用 LLM_* 配置
LLM_PROVIDER=mock
LLM_MODEL_NAME=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
LLM_FALLBACK_TO_MOCK=false

# 本机 Ollama 配置。
# 当前本机可用聊天模型包括：qwen2.5:3b、gemma3:4b、qwen3.5:9b、deepseek-r1:14b。
# 推荐先用 qwen2.5:3b，返回 JSON 更快，适合接口联调。
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen2.5:3b
